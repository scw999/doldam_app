{
  "name": "@doldam/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:local": "wrangler d1 execute DOLDAM_DB --local --file=src/db/schema.sql && wrangler d1 execute DOLDAM_DB --local --file=src/db/seed.sql",
    "db:remote": "wrangler d1 execute DOLDAM_DB --remote --file=src/db/schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250121.0",
    "typescript": "^5.7.3",
    "wrangler": "^4.83.0"
  }
}
