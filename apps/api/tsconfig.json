{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": [
      "@cloudflare/workers-types"
    ],
    "lib": [
      "ES2022"
    ],
    "jsx": "react-jsx",
    "noEmit": true
  },
  "include": [
    "src/**/*.ts"
  ],
  "extends": "expo/tsconfig.base"
}
